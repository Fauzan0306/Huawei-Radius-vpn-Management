# -----------------------------------------------------------------------------
# App server
# -----------------------------------------------------------------------------
# Host/IP yang dipakai backend Express untuk bind.
HOST=0.0.0.0

# Port backend Express.
PORT=3000

# URL frontend saat development. Dipakai untuk CORS credentialed requests.
CLIENT_URL=http://localhost:5173

# Secret untuk sign/verify JWT cookie admin.
JWT_SECRET=change-this-secret


# -----------------------------------------------------------------------------
# Admin login
# -----------------------------------------------------------------------------
# Username admin aplikasi. Login admin masih berbasis .env, bukan database.
ADMIN_USERNAME=admin

# Password admin plaintext. Gunakan ini jika belum memakai hash.
ADMIN_PASSWORD=admin123

# Password admin versi bcrypt hash. Jika diisi, backend akan memprioritaskan ini.
ADMIN_PASSWORD_HASH=

# Data profil admin yang ditampilkan di sidebar frontend.
ADMIN_DISPLAY_NAME=Primary Operator
ADMIN_EMAIL=admin@example.com


# -----------------------------------------------------------------------------
# Timezone operasional aplikasi
# -----------------------------------------------------------------------------
# Nilai offset menit untuk filter tanggal operasional.
# -480 = UTC+08:00 (Makassar / WITA)
APP_TIMEZONE_OFFSET_MINUTES=-480


# -----------------------------------------------------------------------------
# Database MariaDB
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=radius
DB_PASSWORD=radius-password
DB_NAME=radius


# -----------------------------------------------------------------------------
# Session source
# -----------------------------------------------------------------------------
# Pilihan:
# - radius  -> baca session dari tabel radacct
# - huawei  -> baca session dari tabel vpn_sessions
SESSION_SOURCE=huawei

# Token untuk internal ingest API Huawei:
# - POST /api/internal/sessions/login
# - POST /api/internal/sessions/logout
SESSION_INGEST_TOKEN=replace-with-long-random-token


# -----------------------------------------------------------------------------
# Huawei snapshot sync
# -----------------------------------------------------------------------------
# Pilihan:
# - disabled
# - command
# - file
HUAWEI_SESSION_SNAPSHOT_MODE=disabled

# Dipakai jika HUAWEI_SESSION_SNAPSHOT_MODE=command
HUAWEI_SESSION_COMMAND=

# Dipakai jika HUAWEI_SESSION_SNAPSHOT_MODE=file
HUAWEI_SESSION_FILE=

# Interval sinkronisasi snapshot dalam detik.
HUAWEI_SESSION_SYNC_INTERVAL_SECONDS=60

# Timeout command snapshot dalam milidetik.
HUAWEI_SESSION_COMMAND_TIMEOUT_MS=15000


# -----------------------------------------------------------------------------
# Huawei syslog listener
# -----------------------------------------------------------------------------
# Aktifkan listener UDP syslog Huawei di proses backend yang sama.
HUAWEI_SYSLOG_LISTENER_ENABLED=true

# Host bind listener syslog.
HUAWEI_SYSLOG_HOST=0.0.0.0

# Port listener syslog.
HUAWEI_SYSLOG_PORT=514

# Offset timestamp syslog Huawei.
# Contoh: +00:00 atau +08:00
HUAWEI_SYSLOG_TIMEZONE=+00:00

# Jendela dedup syslog dalam detik untuk menghindari event duplikat.
HUAWEI_SYSLOG_DEDUP_WINDOW_SECONDS=10

# Jika true, pesan syslog yang diabaikan akan ikut dicatat ke log aplikasi.
HUAWEI_SYSLOG_LOG_IGNORED=false


# -----------------------------------------------------------------------------
# RADIUS disconnect / CoA
# -----------------------------------------------------------------------------
# Konfigurasi ini dibutuhkan jika fitur force disconnect/cut session diaktifkan.
RADIUS_NAS_IP=
RADIUS_COA_SECRET=
RADIUS_COA_PORT=3799
